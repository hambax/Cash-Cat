{
  "name": "cash-cat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,engine -c blue,green \"vite\" \"npm run engine\"",
    "dev:ui": "vite",
    "dev:full": "npm run dev",
    "build": "tsc && vite build",
    "bundle:engine": "node scripts/bundle-engine.mjs",
    "build:engine-sidecar": "bash scripts/build-engine-sidecar.sh",
    "package:dmg": "bash scripts/create-dmg.sh",
    "tauri:release": "npm run tauri build && npm run package:dmg",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "typecheck": "tsc --noEmit",
    "engine": "cd engine && python3 -m uvicorn cash_cat.app:app --host 127.0.0.1 --port 8787 --reload",
    "lint:a11y": "echo \"Run axe or eslint-plugin-jsx-a11y in CI when added\""
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.544.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.18.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
