# Point the UI at a manually run engine (when Tauri spawn is not used)
# VITE_ENGINE_URL=http://127.0.0.1:8787

# Engine: comma-separated browser origins for CORS (defaults include Vite and Tauri). Use * for allow-all (not recommended).
# CASH_CAT_CORS_ORIGINS=http://127.0.0.1:1420,http://localhost:5173
